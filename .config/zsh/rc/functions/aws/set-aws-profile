#!/usr/bin/env zsh

local selected_profile=$(aws configure list-profiles |
  grep -v "default" |
  sort |
  fzf --prompt "Select PROFILE. If press Ctrl-C, unset PROFILE. > " \
      --height 50% --layout=reverse --border --preview-window 'right:50%' \
      --preview "grep {} -A5 ~/.aws/config")

if [ -z "$selected_profile" ]; then
  echo "Unset aws profile!"
  unset AWS_PROFILE AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY
  return
fi

echo "Set the environment variable 'AWS_PROFILE' to '${selected_profile}'!"
export AWS_PROFILE="$selected_profile"
unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY

# assume-role プロファイルなら source_profile で SSO ログインする
local source_profile
source_profile=$(aws configure get source_profile --profile "${selected_profile}" 2>/dev/null)
local login_profile="${source_profile:-$selected_profile}"

# aws sso login は有効セッションがあればブラウザを開かず終了するので毎回呼ぶ
# (aws sts などで先に precheck すると AWS CLI v2 の自動再ログインで余計にブラウザが開く)
if ! aws sso login --profile "${login_profile}"; then
  echo "SSO login failed for profile '${login_profile}'"
  return 1
fi

aws sts get-caller-identity
